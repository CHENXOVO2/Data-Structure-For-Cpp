#include<iostream>
#include<vector>
using namespace std;
int main() {
	vector<int>arr = { 10,20,30,40 };
	//Random Access
	cout << "arr[0] = " << arr[0] << endl;
	cout << "arr[1] = " << arr[1] << endl;
	arr.push_back(50);
	arr.pop_back();
	//Insert and Erase
	arr.insert(arr.begin() + 1, 15);
	arr.erase(arr.begin() + 2);
	//Iterate
	for (int i = 0; i < arr.size(); i++) {
		cout << "arr[" << i << "] = " << arr[i] << endl;
	}
	for(int x:arr) {
		cout << x << " ";
	}

}
